# ── Environment ──
# "development" or "production"
APP_ENV=development

# ── Database ──
# PostgreSQL connection URL.
# Run setup_postgres.bat ONCE to create the user and database.
DATABASE_URL=postgresql://sentineledge:sentineledge123@localhost:5432/sentineledge

# ── Thresholds ──
# High temperature threshold (overheating danger)
TEMP_THRESHOLD_HIGH=90.0
# Low temperature threshold (cooled and ready)
TEMP_THRESHOLD_LOW=42.0

# ── SMTP (Email Alerts) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ── SMS Configuration ──
# "adb" (development), "gammu" (production USB modem), or "gateway" (REST API)
SMS_METHOD=adb
# For SMS_METHOD=gateway
SMS_GATEWAY_URL=http://192.168.1.100:8080
SMS_GATEWAY_USER=admin
SMS_GATEWAY_PASS=password
# For SMS_METHOD=gammu (USB GSM Modem)
SMS_GAMMU_PORT=COM3
SMS_GAMMU_BAUD=9600
# For SMS_METHOD=adb
SMS_ADB_SERIAL=emulator-5554

# ── Sensor Configuration ──
# Set to "true" to replay CSV data. "false" to read live USB sensor.
DEMO_MODE=true
# For live USB sensor (when DEMO_MODE=false)
SENSOR_PORT=COM3
SENSOR_BAUD=9600

# ── Escalation / Cooldown ──
# Minimum time between alerts of the same type/direction
ALERT_COOLDOWN_SECONDS=10
ESCALATION_TIMEOUT_SECONDS=60
DEMO_ESCALATION_TIMEOUT=15

# ── Web Push (VAPID) ──
VAPID_PUBLIC_KEY=your_public_key
VAPID_PRIVATE_KEY=your_private_key
VAPID_CLAIM_EMAIL=admin@sentineledge.local

# ── Server ──
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# ── Admin Credentials ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sentineledge-admin
